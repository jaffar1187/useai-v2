{
  "name": "@useai/storage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": { "development": "./src/index.ts", "default": "./dist/index.js" },
    "./paths": { "development": "./src/paths.ts", "default": "./dist/paths.js" },
    "./sessions": { "development": "./src/sessions.ts", "default": "./dist/sessions.js" },
    "./config": { "development": "./src/config.ts", "default": "./dist/config.js" },
    "./keystore": { "development": "./src/keystore.ts", "default": "./dist/keystore.js" }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@useai/types": "workspace:*",
    "@useai/crypto": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "vitest": "^3.0.0"
  }
}
